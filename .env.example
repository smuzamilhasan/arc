# =============================================================================
# Arc — Environment Variables
# Copy this file, fill in real values, and set them in Railway → Variables.
# NEVER commit a .env file with real secrets to git.
# =============================================================================

# -----------------------------------------------------------------------------
# CORE APPLICATION
# -----------------------------------------------------------------------------

# The fully-qualified public URL of this deployment (no trailing slash).
# Used in invite email links and OG meta tags.
APP_ORIGIN=https://buildmyarc.com

# AES-256-GCM symmetric key used to encrypt stored marketing connector secrets.
# CRITICAL: must be the same value as on Replit — changing it makes all stored
# connector API keys permanently unreadable. Export from Replit Secrets first.
APP_ENCRYPTION_KEY=your-random-32-plus-char-string-here

# Pino log level: trace | debug | info | warn | error | silent
LOG_LEVEL=info

# Set automatically by Railway. Do not set manually unless testing locally.
NODE_ENV=production

# Set automatically by Railway. Do not set manually.
# PORT=8080

# -----------------------------------------------------------------------------
# DATABASE (set automatically by Railway PostgreSQL plugin)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# AUTHENTICATION — Clerk (https://dashboard.clerk.com)
# -----------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>

# Comma-separated list of email addresses with admin access.
ADMIN_EMAILS=you@example.com

# -----------------------------------------------------------------------------
# AI — OpenAI (https://platform.openai.com/api-keys)
# -----------------------------------------------------------------------------
AI_INTEGRATIONS_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# AI — Anthropic (https://console.anthropic.com/settings/keys)
# -----------------------------------------------------------------------------
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

# -----------------------------------------------------------------------------
# AI — Google Gemini (https://aistudio.google.com/apikey)
# -----------------------------------------------------------------------------
AI_INTEGRATIONS_GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# -----------------------------------------------------------------------------
# EMAIL — Resend (https://resend.com/api-keys)
# -----------------------------------------------------------------------------
# Direct Resend API key — replaces the former Replit connector proxy.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verified sending address. Must match a domain verified in your Resend account.
RESEND_FROM=arc <hello@yourdomain.com>

# -----------------------------------------------------------------------------
# TYPEFORM (https://admin.typeform.com → Settings → Personal tokens)
# Replaces the former Replit OAuth connector proxy.
# -----------------------------------------------------------------------------
TYPEFORM_API_TOKEN=tfp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret Typeform uses to sign webhook payloads (HMAC-SHA256).
# Set this in your Typeform webhook settings too.
MARKETING_TYPEFORM_WEBHOOK_SECRET=your-random-webhook-secret-here

# Fallback webhook secret if MARKETING_TYPEFORM_WEBHOOK_SECRET is not set.
MARKETING_WEBHOOK_SECRET=your-fallback-webhook-secret-here

# Optional tuning (defaults shown):
# MARKETING_TYPEFORM_PAGE_SIZE=1000
# MARKETING_TYPEFORM_POLL_MS=300000

# -----------------------------------------------------------------------------
# MARKETING CONNECTORS — BYO-Key (optional; users can also configure in UI)
# These are server-side env fallbacks. Per-client keys take precedence.
# -----------------------------------------------------------------------------

# Make.com
MARKETING_MAKE_API_KEY=
MARKETING_MAKE_API_BASE_URL=https://eu1.make.com/api/v2

# Instantly
MARKETING_INSTANTLY_API_KEY=

# Beehiiv
MARKETING_BEEHIIV_API_KEY=

# Airtable
MARKETING_AIRTABLE_API_KEY=
MARKETING_AIRTABLE_ACCOUNT_REF=

# Resend (BYO — for per-client email sending, separate from the platform key)
MARKETING_RESEND_API_KEY=

# -----------------------------------------------------------------------------
# TESTING ONLY — not needed in Railway production
# -----------------------------------------------------------------------------
# E2E_BASE_URL=http://localhost:80
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
