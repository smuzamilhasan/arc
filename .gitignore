# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Playwright
test-results
playwright-report

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit (excluded from Railway deployments)
.cache/
.local/
.replit
replit.nix

# Environment variables — never commit real secrets
.env
*.env
.env.local
.env.*.local

# Root secret files (Cloudflare token, Clerk secret, DB URL) — never commit
.cf-token
.clerk-secret
.db-url

# Clerk user exports (PII) — never commit
clerk-users*.json
clerk-id-map.json
arc_backup*

# One-off cleanup-script backups (contain prod row snapshots) — never commit
scripts/v2/backups/
